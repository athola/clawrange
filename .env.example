# AI MSP Testbed — Environment Configuration Template
# Copy this to .env and fill in real values:  cp .env.example .env

# OpenRouter API key — get from https://openrouter.ai/settings/keys
# Keep balance above $10 for testing. All LLM calls route through this.
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Total credits deposited on OpenRouter (used to calculate remaining balance).
# The proxy blocks paid-tier fallback when balance drops near $10 to protect
# the 1000 req/day free quota. Update this when you add credits.
OPENROUTER_CREDIT_BALANCE=15.00

# OpenClaw gateway auth token — change this to something unique per deployment
OPENCLAW_GATEWAY_TOKEN=testbed-token-change-me

# Service ports (defaults match the testbed guide)
OPENCLAW_PORT=3000
WORKFLOWS_PORT=5678
DEERFLOW_PORT=2026

# Tailscale IP of this node — required for production mode (make start-prod)
# Find yours with: tailscale ip -4
TAILSCALE_IP=

# Z.AI API key — for GLM 5.1 direct access (Tier 2 fallback)
# Get from Z.AI dashboard
ZAI_API_KEY=your-zai-key-here

# Internal auth token for LLM proxy endpoint
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
PROXY_AUTH_TOKEN=generate-a-token-here

# Telegram bot notifications — for rate limit and fallback alerts
# Create bot via @BotFather, get chat ID from /getUpdates
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here

# Timezone for all services (activeHours, cron schedules, logs)
TIMEZONE=America/Chicago

# ─── Marketing Orchestrator ───────────────────────────────────────

# Reddit API — script app via https://www.reddit.com/prefs/apps
# Create a "script" type app (for personal use, not OAuth flow)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
REDDIT_USER_AGENT=clawrange-marketing-bot/0.1

# GitHub PAT — for search API and repo traffic stats
# Needs repo scope for traffic endpoints, public_repo for search
GITHUB_PAT=

# Scheduler timezone (defaults to America/Chicago)
SCHEDULER_TZ=America/Chicago
